    "@tanstack/react-query-devtools": "5.100.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "dotenv": "17.4.2",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "typescript": "6.0.3",
    "vite": "8.0.11",
    "vite-tsconfig-paths": "5.1.4"
