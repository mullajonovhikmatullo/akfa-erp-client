    "@store/store-view": "workspace:*",
    "@hookform/resolvers": "5.2.2",
    "@phosphor-icons/react": "2.1.10",
    "@tanstack/react-query": "5.100.9",
    "antd": "6.3.7",
    "axios": "1.16.0",
    "clsx": "2.1.1",
    "dayjs": "1.11.20",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.75.0",
    "react-router-dom": "7.15.0",
    "recharts": "3.8.1",
