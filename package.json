{
  "name": "store-management-client-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.15.1",
  "scripts": {
    "package:store": "PATH=$PWD/tools:$PATH pnpm -F @store/store",
    "package:landing": "PATH=$PWD/tools:$PATH pnpm -F @store/landing",
    "package:platform": "PATH=$PWD/tools:$PATH pnpm -F @store/platform",
    "dev": "PATH=$PWD/tools:$PATH pnpm --filter @store/store dev",
    "dev:store": "PATH=$PWD/tools:$PATH pnpm --filter @store/store dev",
    "dev:landing": "PATH=$PWD/tools:$PATH pnpm --filter @store/landing dev",
    "dev:platform": "PATH=$PWD/tools:$PATH pnpm --filter @store/platform dev",
    "start:store": "PATH=$PWD/tools:$PATH pnpm package:store start",
    "start:landing": "PATH=$PWD/tools:$PATH pnpm package:landing start",
    "start:platform": "PATH=$PWD/tools:$PATH pnpm package:platform start",
    "build": "PATH=$PWD/tools:$PATH turbo run build",
    "build:store": "PATH=$PWD/tools:$PATH pnpm --filter @store/store build",
    "build:landing": "PATH=$PWD/tools:$PATH pnpm --filter @store/landing build",
    "build:platform": "PATH=$PWD/tools:$PATH pnpm --filter @store/platform build",
    "contracts:sync": "node scripts/sync-openapi-contracts.mjs",
    "contracts:check": "node scripts/sync-openapi-contracts.mjs --check",
    "typecheck": "PATH=$PWD/tools:$PATH turbo run typecheck",
    "lint": "PATH=$PWD/tools:$PATH turbo run lint",
    "preview": "PATH=$PWD/tools:$PATH pnpm --filter @store/store preview",
    "clean": "PATH=$PWD/tools:$PATH turbo run clean",
    "full-clean": "node ./scripts/full-clean.mjs",
    "test:e2e": "PATH=$PWD/tools:$PATH pnpm --filter @store/store test:e2e",
    "test:e2e:ui": "PATH=$PWD/tools:$PATH pnpm --filter @store/store test:e2e:ui",
    "test:e2e:debug": "PATH=$PWD/tools:$PATH pnpm --filter @store/store test:e2e:debug",
    "test:e2e:report": "PATH=$PWD/tools:$PATH pnpm --filter @store/store test:e2e:report"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "turbo": "2.10.5",
    "typescript": "6.0.3"
  }
}
